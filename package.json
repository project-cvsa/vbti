{
	"name": "vbti",
	"private": true,
	"version": "2.3.1",
	"type": "module",
	"scripts": {
		"dev": "bunx --bun vite",
		"build": "bunx --bun vite build",
		"build:rednote": "bunx --bun vite build --mode rednote --outDir dist-rednote",
		"build:bili": "bunx --bun vite build --mode bilibili --outDir dist-bili",
		"lint": "bunx --bun biome lint",
		"preview": "bunx --bun vite preview",
		"preview:rednote": "bunx --bun vite preview --outDir dist-rednote",
		"preview:bili": "bunx --bun vite preview --outDir dist-bili",
		"format": "bunx --bun biome format --write .",
		"test": "bunx --bun vitest run"
	},
	"dependencies": {
		"@fontsource-variable/inter": "^5.2.8",
		"@tailwindcss/vite": "^4.2.4",
		"@thumbmarkjs/thumbmarkjs": "^1.8.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"jotai": "^2.19.1",
		"lucide-react": "^1.14.0",
		"next-themes": "^0.4.6",
		"qrcode": "^1.5.4",
		"radix-ui": "^1.4.3",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-router": "^7.14.2",
		"shadcn": "^4.6.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "3",
		"tw-animate-css": "^1.4.0",
		"web-vitals": "^5.2.0"
